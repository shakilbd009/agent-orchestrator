# =============================================================================
# Agent Orchestrator Platform — Phase 0 Environment Contract
# =============================================================================
# This file defines the complete env var surface for Phase 0.
# All feature flags default to false; override in .env.local for local dev.
#
# Version contract (read-only — do not override):
GO_VERSION=1.25.6
NODE_VERSION=v25.3.0
PNPM_VERSION=10.32.1
DOCKER_COMPOSE_VERSION=v5.0.2

# =============================================================================
# Feature Flags (server namespace)
# All FF_ENABLE_* vars default to false; set true to activate
# =============================================================================
FF_ENABLE_APP_SHELL=false

# =============================================================================
# Feature Flags (client/browser namespace)
# VITE_FF_ENABLE_* mirrors FF_ENABLE_* for browser runtime embedding
# =============================================================================
VITE_FF_ENABLE_APP_SHELL=false

# =============================================================================
# Dev server ports (defaults — override in .env.local if ports conflict)
# =============================================================================
APP_PORT=8080
FRONTEND_PORT=5173
DATABASE_PORT=5432
CACHE_PORT=6379

# =============================================================================
# Docker Compose command contract
# Use: docker-compose (standalone v5.0.2), NOT: docker compose (v2 plugin)
# =============================================================================
DOCKER_COMPOSE_COMMAND=docker-compose

# =============================================================================
# Optional: GH_TOKEN for GitHub API access (needed for some agent operations)
# =============================================================================
# GH_TOKEN=
